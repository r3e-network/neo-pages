# Shared
NODE_ENV=development
NEOPAGES_ROOT_DOMAIN=neopages.dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
EDGE_PUBLIC_ORIGIN=http://localhost:8787

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=change-me
GITHUB_WEBHOOK_SECRET=change-me
GITHUB_ACCESS_TOKEN=
GITHUB_WEBHOOK_TARGET=https://dashboard.neopages.dev/api/github/webhook

GITHUB_INSTALLATION_CACHE_TTL_MS=300000

# Builder
BUILDER_PORT=4000
BUILDER_PUBLIC_URL=http://localhost:4000
BUILDER_SANDBOX_MODE=local
BUILDER_POLL_INTERVAL_MS=0
BUILDER_WORKDIR=.tmp/builder
BUILDER_DOCKER_IMAGE=node:22-bookworm
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=data/storage
NEOFS_GATEWAY_ORIGIN=http://http.fs.neo.org/gw

# NeoFS adapter
NEOFS_RPC_ENDPOINT=
NEOFS_WALLET_PATH=
NEOFS_WALLET_PASSWORD=
NEOFS_CONTAINER_POLICY=REP 2 IN X CBF 3 SELECT 2 FROM * AS X
NEOFS_CONTAINER_BASIC_ACL=0x1FBF
NEOFS_CLI_BIN=neofs-cli

USAGE_INGEST_SECRET=change-me

# Gateway / Cloudflare
GATEWAY_PORT=8787
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
DASHBOARD_ORIGIN=http://localhost:3000
CACHE_TTL_SECONDS=60
